# Default 5050 avoids macOS AirPlay Receiver using port 5000 (Control Center).
PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/video-stream-app
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
#for local development
CLIENT_ORIGIN=http://localhost:5173
#for vercel deployment
CLIENT_ORIGIN=https://stream-sence.vercel.app 
MAX_VIDEO_SIZE_MB=500
# Disk folder for new uploads (storedFilename). GridFS is only for older rows with gridFileId.
UPLOAD_DIR=./uploads
# Optional tuning (bytes): disk stream read buffer (default ~4MB, max 16MB), GridFS→socket bridge (default ~4MB, max 32MB).
# VIDEO_STREAM_READ_BUFFER=4194304
# VIDEO_GRIDFS_BUFFER=4194304
